{
  "name": "PeerLoop - User Onboarding Automation",
  "nodes": [
    {
      "parameters": {
        "path": "peers/user-onboarding",
        "httpMethod": "POST",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "1",
      "name": "Onboarding Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        120,
        320
      ]
    },
    {
      "parameters": {
        "functionCode": "const payload = $json.body ?? $json;\n\nconst required = ['userId', 'username'];\nconst missing = required.filter((field) => {\n  const value = payload[field];\n  return value === undefined || value === null || String(value).trim() === '';\n});\n\nif (missing.length > 0) {\n  throw new Error(`Invalid onboarding payload: missing ${missing.join(', ')}`);\n}\n\nconst correlationId = payload.correlationId && String(payload.correlationId).trim()\n  ? String(payload.correlationId).trim()\n  : `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;\n\nreturn [{\n  json: {\n    userId: String(payload.userId).trim(),\n    username: String(payload.username).trim(),\n    email: payload.email ? String(payload.email).trim() : '',\n    locale: payload.locale ? String(payload.locale).trim() : 'fr-FR',\n    registeredAt: payload.registeredAt ? String(payload.registeredAt) : new Date().toISOString(),\n    correlationId\n  }\n}];"
      },
      "id": "2",
      "name": "Validate Onboarding Payload",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        380,
        320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$env.N8N_ONBOARDING_NOTIFICATION_WEBHOOK_URL || ''}}",
              "operation": "regex",
              "value2": "^https?://"
            }
          ]
        }
      },
      "id": "3",
      "name": "Notification Endpoint Configured?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        640,
        320
      ]
    },
    {
      "parameters": {
        "url": "={{$env.N8N_ONBOARDING_NOTIFICATION_WEBHOOK_URL}}",
        "method": "POST",
        "jsonParameters": true,
        "options": {
          "timeout": 10000
        },
        "bodyParametersJson": "={{ JSON.stringify({ type: 'user_welcome_notification', userId: $node['Validate Onboarding Payload'].json.userId, title: 'Bienvenue sur PeerLoop', message: 'Bienvenue ' + $node['Validate Onboarding Payload'].json.username + ' ! Ton espace est prêt.', locale: $node['Validate Onboarding Payload'].json.locale, correlationId: $node['Validate Onboarding Payload'].json.correlationId }) }}"
      },
      "id": "4",
      "name": "Send In-App Welcome",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        920,
        220
      ],
      "continueOnFail": true,
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$env.N8N_ONBOARDING_EMAIL_WEBHOOK_URL || ''}}",
              "operation": "regex",
              "value2": "^https?://"
            },
            {
              "value1": "={{$node['Validate Onboarding Payload'].json.email || ''}}",
              "operation": "regex",
              "value2": ".+@.+"
            }
          ]
        }
      },
      "id": "5",
      "name": "Email Endpoint Configured? (After Notification)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
