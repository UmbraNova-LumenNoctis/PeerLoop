      },
      "id": "1",
      "name": "Onboarding Pro Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        120,
        320
      ]
    },
    {
      "parameters": {
        "functionCode": "const payload = $json.body ?? $json;\n\nconst required = ['userId', 'username'];\nconst missing = required.filter((field) => {\n  const value = payload[field];\n  return value === undefined || value === null || String(value).trim() === '';\n});\n\nif (missing.length > 0) {\n  throw new Error(`Invalid onboarding payload: missing ${missing.join(', ')}`);\n}\n\nconst correlationId = payload.correlationId && String(payload.correlationId).trim()\n  ? String(payload.correlationId).trim()\n  : `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;\n\nreturn [{\n  json: {\n    userId: String(payload.userId).trim(),\n    username: String(payload.username).trim(),\n    email: payload.email ? String(payload.email).trim() : '',\n    locale: payload.locale ? String(payload.locale).trim() : 'fr-FR',\n    plan: payload.plan ? String(payload.plan).trim() : 'free',\n    source: payload.source ? String(payload.source).trim() : 'signup',\n    registeredAt: payload.registeredAt ? String(payload.registeredAt) : new Date().toISOString(),\n    correlationId\n  }\n}];"
      },
