        },
        "bodyParametersJson": "={{ JSON.stringify({ type: 'user_welcome_email', to: $node['Validate Onboarding Payload'].json.email, username: $node['Validate Onboarding Payload'].json.username, subject: 'Bienvenue sur PeerLoop', template: 'welcome_v1', locale: $node['Validate Onboarding Payload'].json.locale, correlationId: $node['Validate Onboarding Payload'].json.correlationId }) }}"
      },
      "id": "6",
