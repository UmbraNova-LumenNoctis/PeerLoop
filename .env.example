# =============================================================================
# peerloop – Docker Compose variable interpolation
#
# This file is read ONLY by Docker Compose for YAML variable substitution.
# It is NOT injected into containers as environment variables.
#
# Variables here configure the Compose file itself (${VAR} references).
# Application secrets are managed exclusively by HashiCorp Vault.
# =============================================================================

# ---- Vault bootstrap --------------------------------------------------------
# Address of the Vault container (internal Docker network)
VAULT_ADDR=https://vault:8200
# Root token — only used to bootstrap Vault, never exposed to application code.
# Generate a unique value with: uuidgen | tr '[:upper:]' '[:lower:]'
VAULT_TOKEN=<generate-with: uuidgen>
# Set to false for local self-signed cert in Vault dev TLS mode.
VAULT_TLS_VERIFY=false

# ---- Frontend ---------------------------------------------------------------
# Leave empty to auto-resolve from browser host/IP. Set explicitly only if needed.
VITE_API_SERVER_URL=

# ---- n8n automation ----------------------------------------------------------
# Public editor URL (behind nginx reverse proxy)
N8N_EDITOR_BASE_URL=https://localhost:8443/services/n8n/
# Public webhook base URL used in generated trigger/callback URLs
N8N_WEBHOOK_URL=https://localhost:8443/services/n8n/
# Generate a strong key (32+ chars), for example:
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=<generate-with: openssl rand -hex 32>
N8N_PROXY_HOPS=1
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=<choose-a-strong-password>
N8N_TIMEZONE=UTC
N8N_LOG_LEVEL=info
# Optional outbound webhook target used by the bundled professional workflow
# (for example: Slack Incoming Webhook URL).
N8N_ALERT_WEBHOOK_URL=
# Optional endpoint for daily operational report notifications.
N8N_DAILY_REPORT_WEBHOOK_URL=
# Optional endpoint to archive full daily reports externally.
N8N_REPORT_ARCHIVE_WEBHOOK_URL=
# Optional endpoint for sending in-app welcome notifications from onboarding workflow.
N8N_ONBOARDING_NOTIFICATION_WEBHOOK_URL=
# Optional endpoint for sending onboarding welcome emails.
N8N_ONBOARDING_EMAIL_WEBHOOK_URL=
# Optional endpoint for CRM contact upsert from onboarding-pro workflow.
N8N_ONBOARDING_CRM_WEBHOOK_URL=
# Optional endpoint for support ticket creation from onboarding-pro workflow.
N8N_ONBOARDING_SUPPORT_WEBHOOK_URL=
# Optional endpoint to store onboarding-pro execution audit events.
N8N_ONBOARDING_AUDIT_WEBHOOK_URL=

# Optional endpoint for moderation team notifications.
N8N_MODERATION_NOTIFICATION_WEBHOOK_URL=
# Optional endpoint to create moderation cases/tickets.
N8N_MODERATION_CASE_WEBHOOK_URL=
# Optional endpoint to apply automatic critical moderation action.
N8N_MODERATION_ACTION_WEBHOOK_URL=

# Optional endpoint for high-risk auth/security notifications.
N8N_SECURITY_ALERT_WEBHOOK_URL=
# Optional endpoint to trigger automatic user/IP blocking on critical auth events.
N8N_SECURITY_BLOCK_WEBHOOK_URL=
# Optional source endpoint returning dormant users list for reactivation workflow.
N8N_REACTIVATION_SOURCE_WEBHOOK_URL=
# Optional endpoint to send reactivation campaign messages.
N8N_REACTIVATION_CAMPAIGN_WEBHOOK_URL=
# Optional endpoint for reactivation campaign delivery audits.
N8N_REACTIVATION_AUDIT_WEBHOOK_URL=
