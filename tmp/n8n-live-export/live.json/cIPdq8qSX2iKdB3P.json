    {
      "parameters": {
        "functionCode": "const user = $items('Validate & Normalize User', 0, 0)[0]?.json || {};\nconst attempted = (nodeName) => $items(nodeName, 0, 0).length > 0;\n\nreturn [{\n  json: {\n    type: 'onboarding_automation_audit',\n    userId: user.userId,\n    username: user.username,\n    email: user.email,\n    plan: user.plan,\n    source: user.source,\n    correlationId: user.correlationId,\n    startedAt: user.registeredAt,\n    finishedAt: new Date().toISOString(),\n    steps: {\n      notification: attempted('Send In-App Welcome') ? 'attempted' : 'skipped',\n      email: attempted('Send Welcome Email') ? 'attempted' : 'skipped',\n      crm: attempted('Upsert CRM Contact') ? 'attempted' : 'skipped',\n      support: attempted('Create Support Ticket') ? 'attempted' : 'skipped'\n    }\n  }\n}];"
      },
