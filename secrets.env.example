# =============================================================================
# peerloop – secrets.env
#
# Copy this file to secrets.env, fill in real values, then run:
#   make vault-push-secrets
#
# The secrets.env file is git-ignored and should NEVER be committed.
# It is read by vault/scripts/init-vault.sh to push secrets into Vault.
# Once the secrets are in Vault, this file is no longer needed at runtime.
# =============================================================================

# ---- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<your-supabase-service-role-key>

# ---- Google OAuth -----------------------------------------------------------
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>
REDIRECT_URI=https://localhost:8443/auth/google/callback
GOOGLE_REDIRECT_URIS=https://localhost:8443/auth/google/callback,https://localhost:8443/api/auth/google/callback,https://localhost:8444/auth/google/callback,https://localhost:8444/api/auth/google/callback
EMAIL_CONFIRM_REDIRECT_URL=https://localhost:8443/api/auth/email/confirm
POST_CONFIRM_APP_URL=https://localhost:8443
GOOGLE_OAUTH_ALLOW_SUPABASE_FALLBACK=false
GOOGLE_OAUTH_AUTO_FALLBACK=true
GOOGLE_REQUIRE_VERIFIED_EMAIL=true
AUTH_STRICT_EMAIL_LINKING=true

# ---- Application internals --------------------------------------------------
# Generate with: openssl rand -hex 32
GATEWAY_SECRET=<generate-with: openssl rand -hex 32>
INTERNAL_SERVICE_TOKEN=<generate-with: openssl rand -hex 32>
ENV=production
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none
REFRESH_TOKEN_COOKIE_NAME=ft_refresh_token
REFRESH_COOKIE_MAX_AGE=2592000
MAX_FILE_SIZE_MB=25
DEFAULT_AVATAR_URL=https://api.dicebear.com/9.x/identicon/svg?seed=peerloop
DEFAULT_COVER_URL=
ENVIRONMENT=production
INTERNAL_TLS_VERIFY=false
AUTH_SERVICE_URL=https://nginx/_internal/auth_service
FILE_SERVICE_URL=https://nginx/_internal/file_service
USER_SERVICE_URL=https://nginx/_internal/users_service
FRIENDSHIP_SERVICE_URL=https://nginx/_internal/friendship_service
POST_SERVICE_URL=https://nginx/_internal/post_service
NOTIFICATION_SERVICE_URL=https://nginx/_internal/notification_service
CHAT_SERVICE_URL=https://nginx/_internal/chat_service
LLM_SERVICE_URL=https://nginx/_internal/llm_service
SEARCH_SERVICE_URL=https://nginx/_internal/search_service
CORS_ALLOW_ORIGINS=https://localhost:8443,https://127.0.0.1:8443,https://localhost:8444,https://127.0.0.1:8444,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ---- LLM / Gemini -----------------------------------------------------------
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash-lite
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.7
LLM_MAX_OUTPUT_TOKENS=512
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_SYSTEM_PROMPT=

# ---- ImageKit / Uploads -----------------------------------------------------
IMAGEKIT_PRIVATE_KEY=<your-imagekit-private-key>
IMAGEKIT_PUBLIC_KEY=<your-imagekit-public-key>
IMAGEKIT_URL=https://ik.imagekit.io/<your-imagekit-id>

# ---- Grafana ----------------------------------------------------------------
GRAFANA_ADMIN_USER=ft_admin
GRAFANA_ADMIN_PASSWORD=<choose-a-strong-password>
