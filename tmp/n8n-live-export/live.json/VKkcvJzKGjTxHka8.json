          ]
        },
        "options": {}
      },
      "id": "2",
      "name": "Report Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        360,
        300
      ]
    },
    {
      "parameters": {
        "url": "http://api-gateway:8000/health",
        "method": "GET",
        "options": {
          "timeout": 10000
        }
      },
      "id": "3",
      "name": "Check API Gateway",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        620,
        120
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "url": "http://auth_service:8001/health",
        "method": "GET",
        "options": {
          "timeout": 10000
        }
      },
      "id": "4",
      "name": "Check Auth Service",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        860,
        120
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "url": "http://search_service:8000/health",
        "method": "GET",
        "options": {
          "timeout": 10000
        }
      },
      "id": "5",
      "name": "Check Search Service",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        1100,
        120
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "url": "http://prometheus:9090/-/healthy",
        "method": "GET",
        "responseFormat": "string",
        "options": {
          "timeout": 10000
        }
      },
      "id": "6",
      "name": "Check Prometheus",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        1340,
        120
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "functionCode": "const context = $items('Report Context', 0, 0)[0]?.json || {};\n\nfunction normalizeError(errorValue) {\n  if (!errorValue) return 'unknown_error';\n  if (typeof errorValue === 'string') return errorValue;\n  if (errorValue.message) return String(errorValue.message);\n  try {\n    return JSON.stringify(errorValue);\n  } catch (_e) {\n    return 'unserializable_error';\n  }\n}\n\nfunction readCheck(nodeName, service) {\n  const item = $items(nodeName, 0, 0)[0];\n  if (!item || !item.json) {\n    return { service, ok: false, error: 'no_output' };\n  }\n\n  const data = item.json;\n  const hasError = Object.prototype.hasOwnProperty.call(data, 'error');\n\n  if (hasError) {\n    return {\n      service,\n      ok: false,\n      error: normalizeError(data.error)\n    };\n  }\n\n  return {\n    service,\n    ok: true,\n    payload: data\n  };\n}\n\nconst checks = [\n  readCheck('Check API Gateway', 'api-gateway'),\n  readCheck('Check Auth Service', 'auth_service'),\n  readCheck('Check Search Service', 'search_service'),\n  readCheck('Check Prometheus', 'prometheus')\n];\n\nconst failedChecks = checks.filter((check) => !check.ok).map((check) => check.service);\nconst overallStatus = failedChecks.length > 0 ? 'degraded' : 'healthy';\n\nreturn [{\n  json: {\n    generatedAt: context.generatedAt || new Date().toISOString(),\n    reportDate: context.reportDate || new Date().toISOString().slice(0, 10),\n    overallStatus,\n    summary: `${checks.length - failedChecks.length}/${checks.length} checks healthy`,\n    failedChecks,\n    checks,\n    recommendedAction: failedChecks.length > 0\n      ? 'Investigate failing services and inspect docker compose logs.'\n      : 'No action required.'\n  }\n}];"
      },
      "id": "7",
      "name": "Build Daily Report",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1600,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$env.N8N_REPORT_ARCHIVE_WEBHOOK_URL || ''}}",
              "operation": "regex",
              "value2": "^https?://"
            }
          ]
        }
      },
      "id": "8",
      "name": "Archive Endpoint Configured?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1860,
        120
      ]
    },
    {
      "parameters": {
        "url": "={{$env.N8N_REPORT_ARCHIVE_WEBHOOK_URL}}",
        "method": "POST",
        "jsonParameters": true,
        "options": {
          "timeout": 10000
        },
        "bodyParametersJson": "={{ JSON.stringify({ type: 'daily_ops_archive', generatedAt: $json.generatedAt, reportDate: $json.reportDate, overallStatus: $json.overallStatus, summary: $json.summary, failedChecks: $json.failedChecks, checks: $json.checks, recommendedAction: $json.recommendedAction }) }}"
      },
      "id": "9",
      "name": "Archive Daily Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        2120,
