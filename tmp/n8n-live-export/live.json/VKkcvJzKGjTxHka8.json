              "name": "reportText",
              "value": "={{ '[PeerLoop][Daily Ops][' + $json.overallStatus.toUpperCase() + '] ' + $json.summary + ' | failed=' + ($json.failedChecks.length ? $json.failedChecks.join(',') : 'none') + ' | date=' + $json.reportDate }}"
            },
            {
              "name": "alertText",
              "value": "={{ '[PeerLoop][ALERT][Daily Ops] Degraded services: ' + ($json.failedChecks.length ? $json.failedChecks.join(',') : 'unknown') + ' | date=' + $json.reportDate }}"
            }
          ]
        },
        "options": {}
