# Host Name
# Leave empty to auto-resolve from browser host (works on localhost and LAN IP/domain).
VITE_API_SERVER_URL=

# Auth Routes
VITE_API_SIGNUP_ENDPOINT=/api/auth/signup
VITE_API_LOGIN_ENDPOINT=/api/auth/login
VITE_API_GOOGLE_AUTH_ENDPOINT=/api/auth/google

# Post Routes
VITE_API_GET_FEED_ENDPOINT=/api/posts
VITE_API_UPLOAD_FILE_ENDPOINT=/api/files/upload
VITE_API_CREATE_POST_ENDPOINT=/api/posts
VITE_API_DELETE_POST_ENDPOINT=/api/posts/{post_id}
VITE_API_UPDATE_POST_ENDPOINT=/api/posts/{post_id}
VITE_API_GET_POST_ENDPOINT=/api/posts/{post_id}
VITE_API_LIKE_POST_ENDPOINT=/api/posts/{post_id}/like
VITE_API_DELETE_LIKE_POST_ENDPOINT=/api/posts/{post_id}/like
VITE_API_COMMENT_LIST_ENDPOINT=/api/posts/{post_id}/comments
VITE_API_INTERACT_COMMENT_ENDPOINT=/api/posts/comments/{comment_id}

#Search Routes
VITE_API_SEARCH_USER=/api/search/users
VITE_API_SEARCH_POST=/api/search/posts

#Notification Routes
VITE_API_CHECKOUT_NOTIFICATIONS_ENDPOINT=/api/notifications/unread-count
VITE_API_READ_NOTIFICATION_ENDPOINT=/api/notifications/{notification_id}/read
VITE_API_UNREAD_NOTIFICATION_ENDPOINT=/api/notifications/{notification_id}/unread
VITE_API_DELETE_NOTIFICATION_ENDPOINT=/api/notifications/{notification_id}
VITE_API_MARK_NOTIFICATION_ALL_READ=/api/notifications/read-all
VITE_API_GET_NOTIFICATION_LIST=/api/notifications

#Chat Routes
VITE_API_GET_CHAT_NOTIFICATIONS_ENDPOINT=/api/chat/conversations

# User Routes
VITE_API_GET_USER_ENDPOINT=/api/user/me
VITE_API_GET_USER_BY_ID_ENDPOINT=/api/user/{user_id}
